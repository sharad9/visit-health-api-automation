        "headers": {
          "Content-Type": "multipart/form-data",
          "authorization": "{{STEP_2_VERIFY_OTP_REQUEST_HEADER_USER_JWT_TOKEN}}",
          "entityId": "{{ENTITY_ID}}"
        },
        "body": {
          "type": "multipart/form-data",
          "file": {

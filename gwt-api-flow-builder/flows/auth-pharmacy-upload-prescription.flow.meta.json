        "timeoutMilliseconds": 10000,
        "retryPolicy": {
          "maximumAttempts": 2,
          "delayMilliseconds": 500
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "phone": "{{USER_PHONE}}",
          "countryCode": "{{COUNTRY_CODE}}",
          "platform": "{{PLATFORM}}"
        }
      },
      "checks": [
        {
          "source": "status"
        },
        {
          "source": "body"
        }
      ]
    },
    {
      "stepIdentifier": "STEP_2_VERIFY_OTP",
      "request": {
        "httpMethod": "POST",
        "requestUrl": "https://api.samuraijack.xyz/latios/new-auth/otp",
        "timeoutMilliseconds": 10000,
        "retryPolicy": {
          "maximumAttempts": 2,
          "delayMilliseconds": 500
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "phone": "{{USER_PHONE}}",
          "otp": "{{USER_OTP}}",
          "platform": "{{PLATFORM}}"
        }
      },
      "extraction": {
        "headerValues": {
          "USER_JWT_TOKEN": "authorization"
        }
      },
      "checks": [
        {
          "source": "status"
        },
        {
          "source": "body"
        }
      ]
    },

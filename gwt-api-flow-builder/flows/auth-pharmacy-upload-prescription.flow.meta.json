            "filePath": "{{PRESCRIPTION_FILE_PATH}}",
            "absoluteFilePath": "{{PRESCRIPTION_ABSOLUTE_FILE_PATH}}",
            "exists": true,
            "fileName": "{{PRESCRIPTION_FILE_NAME}}",
            "fileSizeBytes": 647
